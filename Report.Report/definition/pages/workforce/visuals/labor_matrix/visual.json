{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/2.7.0/schema.json",
  "name": "labor_matrix",
  "position": {
    "x": 650,
    "y": 460,
    "z": 10,
    "height": 240,
    "width": 610,
    "tabOrder": 10
  },
  "visual": {
    "visualType": "pivotTable",
    "query": {
      "queryState": {
        "Rows": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "Dim_Department"
                    }
                  },
                  "Property": "DepartmentName"
                }
              },
              "queryRef": "Dim_Department.DepartmentName",
              "nativeQueryRef": "DepartmentName",
              "active": true
            }
          ]
        },
        "Values": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "_Measures"
                    }
                  },
                  "Property": "Headcount"
                }
              },
              "queryRef": "_Measures.Headcount",
              "nativeQueryRef": "Headcount"
            },
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "_Measures"
                    }
                  },
                  "Property": "Total Labor Cost"
                }
              },
              "queryRef": "_Measures.Total Labor Cost",
              "nativeQueryRef": "Total Labor Cost"
            },
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "_Measures"
                    }
                  },
                  "Property": "Overtime %"
                }
              },
              "queryRef": "_Measures.Overtime %",
              "nativeQueryRef": "Overtime %"
            },
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "_Measures"
                    }
                  },
                  "Property": "Turnover"
                }
              },
              "queryRef": "_Measures.Turnover",
              "nativeQueryRef": "Turnover"
            }
          ]
        }
      }
    },
    "drillFilterOtherVisuals": true
  }
}