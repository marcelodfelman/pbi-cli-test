{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/2.7.0/schema.json",
  "name": "rev_by_channel",
  "position": {
    "x": 840,
    "y": 190,
    "z": 10,
    "height": 250,
    "width": 420,
    "tabOrder": 10
  },
  "visual": {
    "visualType": "barChart",
    "query": {
      "queryState": {
        "Category": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "Dim_Channel"
                    }
                  },
                  "Property": "ChannelName"
                }
              },
              "queryRef": "Dim_Channel.ChannelName",
              "nativeQueryRef": "ChannelName",
              "active": true
            }
          ]
        },
        "Y": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "_Measures"
                    }
                  },
                  "Property": "Net Revenue"
                }
              },
              "queryRef": "_Measures.Net Revenue",
              "nativeQueryRef": "Net Revenue"
            }
          ]
        }
      }
    },
    "drillFilterOtherVisuals": true
  }
}