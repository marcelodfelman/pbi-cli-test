{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/2.7.0/schema.json",
  "name": "property_matrix",
  "position": {
    "x": 20,
    "y": 460,
    "z": 9,
    "height": 240,
    "width": 1240,
    "tabOrder": 9
  },
  "visual": {
    "visualType": "pivotTable",
    "query": {
      "queryState": {
        "Rows": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "Dim_Property"
                    }
                  },
                  "Property": "PropertyName"
                }
              },
              "queryRef": "Dim_Property.PropertyName",
              "nativeQueryRef": "PropertyName",
              "active": true
            }
          ]
        },
        "Values": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "_Measures"
                    }
                  },
                  "Property": "Total Revenue"
                }
              },
              "queryRef": "_Measures.Total Revenue",
              "nativeQueryRef": "Total Revenue"
            },
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "_Measures"
                    }
                  },
                  "Property": "RevPAR"
                }
              },
              "queryRef": "_Measures.RevPAR",
              "nativeQueryRef": "RevPAR"
            },
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "_Measures"
                    }
                  },
                  "Property": "GOPPAR"
                }
              },
              "queryRef": "_Measures.GOPPAR",
              "nativeQueryRef": "GOPPAR"
            },
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "_Measures"
                    }
                  },
                  "Property": "Occupancy %"
                }
              },
              "queryRef": "_Measures.Occupancy %",
              "nativeQueryRef": "Occupancy %"
            },
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "_Measures"
                    }
                  },
                  "Property": "Net Profit Margin %"
                }
              },
              "queryRef": "_Measures.Net Profit Margin %",
              "nativeQueryRef": "Net Profit Margin %"
            }
          ]
        }
      }
    },
    "drillFilterOtherVisuals": true
