{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/2.7.0/schema.json",
  "name": "supplier_matrix",
  "position": {
    "x": 650,
    "y": 460,
    "z": 9,
    "height": 240,
    "width": 610,
    "tabOrder": 9
  },
  "visual": {
    "visualType": "pivotTable",
    "query": {
      "queryState": {
        "Rows": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "Dim_Supplier"
                    }
                  },
                  "Property": "SupplierName"
                }
              },
              "queryRef": "Dim_Supplier.SupplierName",
              "nativeQueryRef": "SupplierName",
              "active": true
            }
          ]
        },
        "Values": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "_Measures"
                    }
                  },
                  "Property": "Total Spend"
                }
              },
              "queryRef": "_Measures.Total Spend",
              "nativeQueryRef": "Total Spend"
            },
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "_Measures"
                    }
                  },
                  "Property": "Price Variance"
                }
              },
              "queryRef": "_Measures.Price Variance",
              "nativeQueryRef": "Price Variance"
            },
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "_Measures"
                    }
                  },
                  "Property": "OTIF %"
                }
              },
              "queryRef": "_Measures.OTIF %",
              "nativeQueryRef": "OTIF %"
            }
          ]
        }
      }
    },
    "drillFilterOtherVisuals": true
  }
}