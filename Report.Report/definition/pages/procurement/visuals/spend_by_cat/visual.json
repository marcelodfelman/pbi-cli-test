{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/2.7.0/schema.json",
  "name": "spend_by_cat",
  "position": {
    "x": 20,
    "y": 195,
    "z": 6,
    "height": 250,
    "width": 620,
    "tabOrder": 6
  },
  "visual": {
    "visualType": "donutChart",
    "query": {
      "queryState": {
        "Category": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "Dim_ProcurementCategory"
                    }
                  },
                  "Property": "CategoryName"
                }
              },
              "queryRef": "Dim_ProcurementCategory.CategoryName",
              "nativeQueryRef": "CategoryName",
              "active": true
            }
          ]
        },
        "Y": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "_Measures"
                    }
                  },
                  "Property": "Total Spend"
                }
              },
              "queryRef": "_Measures.Total Spend",
              "nativeQueryRef": "Total Spend"
            }
          ]
        }
      }
    },
    "drillFilterOtherVisuals": true
  }
}