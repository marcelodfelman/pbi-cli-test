{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/2.7.0/schema.json",
  "name": "spend_trend",
  "position": {
    "x": 20,
    "y": 460,
    "z": 8,
    "height": 240,
    "width": 620,
    "tabOrder": 8
  },
  "visual": {
    "visualType": "lineChart",
    "query": {
      "queryState": {
        "Category": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "Dim_Date"
                    }
                  },
                  "Property": "MonthName"
                }
              },
              "queryRef": "Dim_Date.MonthName",
              "nativeQueryRef": "MonthName",
              "active": true
            }
          ]
        },
        "Y": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "_Measures"
                    }
                  },
                  "Property": "Total Spend"
                }
              },
              "queryRef": "_Measures.Total Spend",
              "nativeQueryRef": "Total Spend"
            }
          ]
        }
      }
    },
    "drillFilterOtherVisuals": true
  }
}