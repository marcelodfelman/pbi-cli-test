{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/2.7.0/schema.json",
  "name": "dept_profit",
  "position": {
    "x": 850,
    "y": 470,
    "z": 11,
    "height": 230,
    "width": 410,
    "tabOrder": 11
  },
  "visual": {
    "visualType": "barChart",
    "query": {
      "queryState": {
        "Category": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "Dim_Department"
                    }
                  },
                  "Property": "DepartmentName"
                }
              },
              "queryRef": "Dim_Department.DepartmentName",
              "nativeQueryRef": "DepartmentName",
              "active": true
            }
          ]
        },
        "Y": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "_Measures"
                    }
                  },
                  "Property": "GOP"
                }
              },
              "queryRef": "_Measures.GOP",
              "nativeQueryRef": "GOP"
            }
          ]
        }
      }
    },
    "drillFilterOtherVisuals": true
  }
}